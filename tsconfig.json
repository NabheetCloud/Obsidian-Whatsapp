{
	"compilerOptions": {
		"baseUrl": ".",
		"module": "ESNext",
		"target": "ES2020",
		"moduleResolution": "node",
		"allowJs": false,
		"noImplicitAny": true,
		"strict": true,
		"strictNullChecks": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"skipLibCheck": true,
		"lib": ["ES2020", "DOM"]
	},
	"include": ["src/**/*.ts"]
}
